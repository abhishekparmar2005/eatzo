PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/eatzo?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret_string
NODE_ENV=production
FRONTEND_URL=https://your-eatzo-frontend.vercel.app

# Keepalive — Render auto-sets this, no action needed
# RENDER_EXTERNAL_URL is set automatically by Render in production
# If deploying elsewhere, set APP_URL=https://your-backend-url.com
